# Startup Insight AI - Backend Environment Configurations

# Security settings
SECRET_KEY=dev-secret-key-replace-in-production-1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database settings
# Uses local SQLite database by default. Switch to PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/startup_insight
DATABASE_URL=sqlite:///./startup_insight.db

# AI API Keys (Optional - Sandbox Mode operates if keys are empty)
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# Payment Gateway Settings (Optional - Sandbox Mode operates if empty)
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
